# Azure Cosmos DB connection
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your-primary-key-here

# Database and container names (defaults match the project spec)
COSMOS_DATABASE=FoodOrdersDB

# Azure Blob Storage — used for item images
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
STORAGE_IMAGE_CONTAINER=item-images

# API Key Authentication (Option 1)
# Production: point to your Key Vault — keys are read from secrets named api-key-*
# Local dev:  leave AZURE_KEYVAULT_URL empty and set API_KEYS instead
AZURE_KEYVAULT_URL=https://<your-keyvault-name>.vault.azure.net/

# Fallback for local dev when AZURE_KEYVAULT_URL is not set
# Generate a key: python -c "import secrets; print(secrets.token_hex(32))"
# API_KEYS=your-64-char-hex-key-here,optional-second-key
